#!/bin/sh
# configure - check for required build dependencies
set -e

check_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Error: '$1' is required but not found. Install it and try again." >&2
        exit 1
    fi
}

check_header() {
    if ! echo "#include <$2>" | ${CXX:-g++} -x c++ - -fsyntax-only 2>/dev/null; then
        echo "Error: Header '$2' not found. Install $1 and try again." >&2
        exit 1
    fi
}

echo "Checking build dependencies..."

check_tool "${CXX:-g++}"
check_tool flex
check_tool bison

check_header libboost-dev boost/filesystem.hpp
check_header libboost-dev boost/program_options.hpp

echo "All dependencies satisfied. Run 'make' to build."
